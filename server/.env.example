# Server - Public Connect API

# Database (MongoDB Atlas URI or local MongoDB)
MONGODB_URI=mongodb+srv://user:pass@cluster0.xxxxx.mongodb.net/public-connect?retryWrites=true&w=majority&appName=Cluster0
# If SRV lookup fails (querySrv ECONNREFUSED), use standard URI from Atlas Connect > Drivers > "I'm using 3.6 or earlier"
# MONGODB_URI_STANDARD=mongodb://user:pass@cluster0-shard-00-00.xxxxx.mongodb.net:27017/public-connect?ssl=true&authSource=admin&retryWrites=true&w=majority

# Port (default: 5000)
PORT=5000

# CORS - comma-separated allowed origins (e.g. https://yourapp.com,https://admin.yourapp.com)
# Leave empty for development to allow all origins
CORS_ORIGIN=

# Admin users - comma-separated phone numbers and emails
ADMIN_PHONE_NUMBERS=
ADMIN_EMAILS=

# Firebase Admin - JSON string of service account (recommended for production)
# Or place serviceAccountKey.json in server/config/
FIREBASE_SERVICE_ACCOUNT=

# Node environment (development | production)
NODE_ENV=development

# Optional: Log level (error|warn|info|debug)
# LOG_LEVEL=info
